<!DOCTYPE html>
<html>
<head>
    <title><%= title %></title>
    <link rel="stylesheet" href="/check-balance.css">
</head>
<body>
  <div class="list-container">
    <h1>Select an Account</h1>
    <div class="button-grid">
      <% accounts.forEach(account => { %>
        <form action="/check-balance/<%= account.id %>" method="get">
          <button type="submit" class="dashboard-btn">
            <%= account.shortcut_name %> - <%= account.bank_name %>
          </button>
        </form>
      <% }) %>
    </div>
    <div class="meta">
      <a href="/dashboard">← Back</a>
    </div>
  </div>
</body>
</html>
