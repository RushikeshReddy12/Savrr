<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <title><%= title %></title>
  <link rel="stylesheet" href="/create-account.css">
</head>
<body>
  <div class="form-container">
    <h2>Create Account</h2>

    <form action="/create-account" method="POST">
      <div class="form-row">
        <label for="account_number">Account Number</label>
        <input id="account_number" name="account_number" type="text" placeholder="e.g. 1234567890" required>
      </div>

      <div class="form-row">
        <label for="bank_name">Bank Name</label>
        <input id="bank_name" name="bank_name" type="text" placeholder="e.g. State Bank of India" required>
      </div>

      <div class="form-row">
        <label for="ifsc_code">IFSC Code</label>
        <input id="ifsc_code" name="ifsc_code" type="text" placeholder="e.g. SBIN0001234" required>
      </div>

      <div class="form-row">
        <label for="shortcut_name">Shortcut Name</label>
        <input id="shortcut_name" name="shortcut_name" type="text" placeholder="e.g. Salary / Savings">
      </div>

      <div class="form-row">
        <label for="income_per_month">Income per Month</label>
        <input id="income_per_month" name="income_per_month" type="number" step="0.01" placeholder="e.g. 25000.00">
      </div>

      <div class="form-row">
        <label for="initial_balance">Initial Balance</label>
        <input id="initial_balance" name="initial_balance" type="number" step="0.01" placeholder="e.g. 1000.00">
      </div>

      <button class="btn-primary" type="submit">Create Account</button>
    </form>

    <div class="meta">
      <a href="/dashboard">← Back to Dashboard</a>
    </div>
  </div>
</body>
</html>
